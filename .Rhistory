infec3 <<- infec2 %>% arrange(desc(Pulse_Wave)) #order by magnitude of pulse wave
max <- as.numeric(infec3[1, "Pulse_Wave"]) #take
rmax <<- (max*0.05+max)
infec2 <- as.data.table(y)
infec3 <<- infec2 %>% arrange(desc(Pulse_Wave)) #order by magnitude of pulse wave
max <- as.numeric(infec3[1, "Pulse_Wave"]) #take
rmax <<- (max*0.05+max)
rmax <- if(rmax > rmax2) rmax else rmax2
